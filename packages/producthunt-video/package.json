{
  "name": "@trace/producthunt-video",
  "version": "2.1.30",
  "private": true,
  "scripts": {
    "studio": "remotion studio src/index.tsx",
    "render": "remotion render src/index.tsx TraceProductHuntLaunch out/trace-product-hunt-launch.mp4 --concurrency=2",
