    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@remotion/media": "4.0.377",
    "remotion": "4.0.377",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@remotion/cli": "4.0.377",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.1.6",
    "typescript": "^5.8.3"
  }
}
